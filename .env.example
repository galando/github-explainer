# Supabase - get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub OAuth App - get from https://github.com/settings/developers
# Callback URL must be: https://your-project.supabase.co/auth/v1/callback
VITE_GITHUB_CLIENT_ID=your-github-client-id

# Google Analytics 4 - get from https://analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase Edge Function Secret (set in Supabase Dashboard > Settings > Edge Functions)
# GROQ_API_KEY=your-groq-api-key   <-- set this in Supabase Secrets, NOT here
